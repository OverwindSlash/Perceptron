      "MaxBboxWidth": 500,
      "MaxBboxHeight": 400,
      "RegionDetectionEnabled": false,
      "DetectionRegion": "1452, 656, 1009, 331",
      "TileDetectionEnabled": false,
      "TileDetectionSize": "1, 2",
      "MaxStitchGapPixel": 3,
      "MinVerticalOverlapRatio": 0.8,
      "WillSuppressInnerSameObject": true,
      "InnerObjectOverlapRatio": 0.7,
      "WillMapObjectTypes": false,
      "SourceObjectTypeNames": "truck,bus",
      "DestinationObjectTypeName": "car",
      "Names": "Alice,Bob,Charlie,David,Eve"
